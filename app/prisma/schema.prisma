generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(uuid())
  name                String?
  email               String    @unique
  password            String?
  emailVerified       DateTime?
  image               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  onboarded           Boolean   @default(false)
  role                UserRole  @default(USER)
  isBanned            Boolean   @default(false)
  mustChangePassword  Boolean   @default(false)

  accounts    Account[]
  sessions    Session[]
  preferences UserPreference?
  userTopics  UserTopic[]
  interactions Interaction[]
  reports     Report[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum UserRole {
  USER
  ADMIN
}

model Topic {
  id          String      @id @default(uuid())
  slug        String      @unique
  name        String
  description String?
  emoji       String?
  userTopics  UserTopic[]
  contents    Content[]
  createdAt   DateTime    @default(now())
}

model UserTopic {
  id            String      @id @default(uuid())
  userId        String
  topicId       String
  weight        Float       @default(1.0)
  status        TopicStatus @default(ACTIVE)
  lastEngagedAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic Topic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
}

enum TopicStatus {
  ACTIVE
  PAUSED
  INACTIVE
  ARCHIVED
}

model UserPreference {
  id        String            @id @default(uuid())
  userId    String            @unique
  postCount Int               @default(20)
  frequency            CurationFrequency @default(DAILY)
  digestUnsubscribed   Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum CurationFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

model Content {
  id          String   @id @default(uuid())
  title       String
  url         String   @unique
  sourceUrl   String?
  summary     String?
  impact      String?
  imageUrl    String?
  source      String   // "reddit" | "hackernews" | "devto" | "rss"
  topicId     String?
  author      String?
  publishedAt DateTime?
  fetchedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  interactions Interaction[]

  topic Topic? @relation(fields: [topicId], references: [id])
}

model Interaction {
  id        String          @id @default(uuid())
  userId    String
  contentId String
  type      InteractionType
  createdAt DateTime        @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId, type])
}

enum InteractionType {
  LIKE
  CLICK
  SAVE
}

model Report {
  id         String       @id @default(uuid())
  userId     String
  message    String
  status     ReportStatus @default(OPEN)
  adminNote  String?
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ReportStatus {
  OPEN
  RESOLVED
}